# Kopiere diese Datei zu ".env" und passe bei Bedarf an.
# ACHTUNG: Garmin-Zugangsdaten gehoeren NICHT hier hinein.
# Login laeuft einmalig ueber "python backend/scripts/login.py" (interaktiv, getpass),
# das Ergebnis ist ein Token-Cache in GARMIN_TOKEN_DIR - kein Klartext-Passwort wird gespeichert.

# Verzeichnis fuer den Garmin-Session-Token-Cache (von scripts/login.py erzeugt)
GARMIN_TOKEN_DIR=.garmin_tokens

# Pfad zur SQLite-Datenbank
DATABASE_URL=sqlite:///./garmin.db

# Intervall des automatischen Hintergrund-Syncs in Minuten
SYNC_INTERVAL_MINUTES=120

# Zeitzone fuer Datumsberechnungen (z.B. "heute")
TZ=Europe/Berlin
